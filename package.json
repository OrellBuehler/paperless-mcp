{
  "name": "@orellbuehler/paperless-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Paperless-ngx: documents, organization, saved views, users, workflows, and optional semantic search.",
  "type": "module",
  "bin": {
    "paperless-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "paperless",
    "paperless-ngx",
    "llm",
    "ai"
  ],
  "author": "Orell Bühler",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OrellBuehler/paperless-mcp.git"
  },
  "homepage": "https://github.com/OrellBuehler/paperless-mcp#readme",
  "bugs": {
    "url": "https://github.com/OrellBuehler/paperless-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0",
    "sqlite-vec": "^0.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.0"
  }
}
